---
import Base from "../layouts/Base.astro";

const base = import.meta.env.BASE_URL;
---

<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <div class="w-16 h-16 rounded-2xl bg-gray-800 border border-gray-700 flex items-center justify-center mb-6">
      <span class="text-3xl font-bold text-gray-500">404</span>
    </div>
    <h1 class="text-2xl font-bold text-white mb-2">Page not found</h1>
    <p class="text-gray-400 mb-8 max-w-md">
      The page you're looking for doesn't exist or may have been moved.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href={base} class="px-4 py-2 bg-aguara-500 hover:bg-aguara-600 text-white text-sm font-medium rounded-lg transition-colors">
        Scan a skill
      </a>
      <a href={`${base}overview/`} class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium rounded-lg border border-gray-700 transition-colors">
        View dashboard
      </a>
    </div>
  </div>
</Base>
