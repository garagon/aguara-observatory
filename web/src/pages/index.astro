    // --- GitHub URL parsing ---
    function parseGitHubUrl(url) {
      url = url.trim().replace(/\.git\/?$/, "");
      var m;
      m = url.match(/^https?:\/\/raw\.githubusercontent\.com\/([^/]+)\/([^/]+)\/([^/]+)\/(.+)$/);
      if (m) return { type: "file", owner: m[1], repo: m[2], branch: m[3], path: m[4] };
      m = url.match(/^https?:\/\/github\.com\/([^/]+)\/([^/]+)\/blob\/([^/]+)\/(.+)$/);
      if (m) return { type: "file", owner: m[1], repo: m[2], branch: m[3], path: m[4] };
      m = url.match(/^https?:\/\/github\.com\/([^/]+)\/([^/]+)\/tree\/([^/]+)\/(.+)$/);
      if (m) return { type: "dir", owner: m[1], repo: m[2], branch: m[3], path: m[4] };
      m = url.match(/^https?:\/\/github\.com\/([^/]+)\/([^/]+)\/tree\/([^/]+)\/?$/);
      if (m) return { type: "repo", owner: m[1], repo: m[2], branch: m[3] };
      m = url.match(/^https?:\/\/github\.com\/([^/]+)\/([^/]+)\/?$/);
      if (m) return { type: "repo", owner: m[1], repo: m[2], branch: null };
      return null;
    }

    function isScannable(path) {
      var lower = path.toLowerCase();
      var filename = lower.split("/").pop();
      if (SKIP_FILES.indexOf(filename) !== -1) return false;
      if (SKIP_DIRS.some(function(d) { return lower.indexOf(d) !== -1; })) return false;
      return SCANNABLE_EXTS.some(function(ext) { return lower.endsWith(ext); });
    }

    function fetchRawFile(owner, repo, branch, path) {
      // Fine-grained PATs don't work with raw.githubusercontent.com — use the Contents API instead
      if (patValidated && githubPat) {
        var apiUrl = "https://api.github.com/repos/" + owner + "/" + repo + "/contents/" + path + "?ref=" + branch;
        return fetch(apiUrl, {
          headers: {
            Authorization: "token " + githubPat,
            Accept: "application/vnd.github.raw+json"
          }
        }).then(function(resp) {
          updateRateLimit(resp);
          if (resp.status === 401 || resp.status === 403 || resp.status === 404) {
            var err = new Error("Failed to fetch " + path + " (" + resp.status + ")");
            err.httpStatus = resp.status;
            throw err;
          }
          if (!resp.ok) throw new Error("Failed to fetch " + path + " (" + resp.status + ")");
          var len = resp.headers.get("content-length");
          if (len && parseInt(len, 10) > MAX_FILE_SIZE) return null;
          return resp.text().then(function(text) {
            return text.length > MAX_FILE_SIZE ? null : text;
          });
        });
      }
      // Public repos: use raw.githubusercontent.com (no API rate limit)
      var rawUrl = "https://raw.githubusercontent.com/" + owner + "/" + repo + "/" + branch + "/" + path;
      return fetch(rawUrl).then(function(resp) {
        if (!resp.ok) throw new Error("Failed to fetch " + path + " (" + resp.status + ")");
        var len = resp.headers.get("content-length");
        if (len && parseInt(len, 10) > MAX_FILE_SIZE) return null;
        return resp.text().then(function(text) {
          return text.length > MAX_FILE_SIZE ? null : text;
        });
      });
    }

    function getDefaultBranch(owner, repo) {
      return fetch("https://api.github.com/repos/" + owner + "/" + repo, { headers: getAuthHeaders() })
        .then(function(resp) {
          updateRateLimit(resp);
          if (!resp.ok) throw new Error("Repository not found or not accessible (" + resp.status + ")");
          return resp.json();
        })
        .then(function(data) { return data.default_branch; });
    }

    function listRepoFiles(owner, repo, branch, basePath) {
      var url = "https://api.github.com/repos/" + owner + "/" + repo + "/git/trees/" + branch + "?recursive=1";
      return fetch(url, { headers: getAuthHeaders() })
        .then(function(resp) {
          updateRateLimit(resp);
          if (!resp.ok) throw new Error("Failed to fetch repo tree (" + resp.status + ")");
          return resp.json();
        })
        .then(function(data) {
          return (data.tree || [])
            .filter(function(f) {
              if (f.type !== "blob") return false;
              // Skip files > MAX_FILE_SIZE by tree size hint
              if (f.size && f.size > MAX_FILE_SIZE) return false;
              return true;
            })
            .map(function(f) { return f.path; })
            .filter(function(p) {
              if (basePath) return p.startsWith(basePath + "/") || p === basePath;
              return true;
            })
            .filter(isScannable);
        });
    }

    // --- Fetch & Scan from GitHub ---
    fetchBtn.addEventListener("click", function() {
      var url = githubUrl.value.trim();
      if (!url) return;

      var parsed = parseGitHubUrl(url);
      if (!parsed) {
        t("scan_url_error", { url_domain: url.indexOf("github.com") !== -1 ? "github" : "other" });
        alert("Please enter a valid GitHub URL.\n\nExamples:\nhttps://github.com/owner/repo\nhttps://github.com/owner/repo/blob/main/skill.md");
        return;
      }

      t("scan_start", { source: "github", type: parsed.type, has_pat: !!patValidated });
      sourceUrl = url;
      wasFileUpload = false;
      setState("loading");
      loadingText.textContent = "Fetching from GitHub...";
      loadingSub.textContent = "";

      var t0 = performance.now();

      if (parsed.type === "file") {
        fetchRawFile(parsed.owner, parsed.repo, parsed.branch, parsed.path)
          .then(function(content) {
            if (!content) throw new Error("File is too large to scan (max 256 KB)");
            var filename = parsed.path.split("/").pop();
            loadingText.textContent = "Scanning " + filename + "...";
            loadingSub.textContent = "First scan loads the WASM engine (~2 MB, cached after)";
            return workerScan(content, filename);
          })
          .then(function(jsonStr) {
            var elapsed = Math.round(performance.now() - t0);
            var result = JSON.parse(jsonStr);
            renderResults(result, parsed.path, elapsed, [parsed.path]);
            setState("results");
            trackScan(result, elapsed);
          })
          .catch(handleError);

      } else {
        var branchPromise = parsed.branch
          ? Promise.resolve(parsed.branch)
          : getDefaultBranch(parsed.owner, parsed.repo);

        var resolvedBranch;
        branchPromise
          .then(function(branch) {
            resolvedBranch = branch;
            loadingText.textContent = "Listing repository files...";
            return listRepoFiles(parsed.owner, parsed.repo, branch, parsed.type === "dir" ? parsed.path : null);
          })
          .then(function(files) {
            if (files.length === 0) {
              throw new Error("No scannable files found.\nSupported: " + SCANNABLE_EXTS.join(", "));
            }
            var capped = files.length > MAX_FILES;
            if (capped) files = files.slice(0, MAX_FILES);
            loadingText.textContent = "Fetching " + files.length + " file" + (files.length > 1 ? "s" : "") + "...";
            loadingSub.textContent = capped ? "(capped at " + MAX_FILES + " files)" : "";
            return fetchAllFiles(parsed.owner, parsed.repo, resolvedBranch, files);
          })
          .then(function(fileContents) {
            if (fileContents.length === 0) throw new Error("All files were too large or failed to fetch.");
            loadingText.textContent = "Scanning " + fileContents.length + " files...";
            loadingSub.textContent = "First scan loads the WASM engine (~2 MB, cached after)";
            return scanMultipleFiles(fileContents);
          })
          .then(function(result) {
            var elapsed = Math.round(performance.now() - t0);
            renderResults(result.merged, result.label, elapsed, result.files);
            setState("results");
            trackScan(result.merged, elapsed);
          })
          .catch(handleError);
      }
    });

    function handleError(err) {
      console.error("Scan error:", err);
      var errorType = "scan_failed";
      var msg = err.message || "";
      if (msg.indexOf("401") !== -1 || msg.indexOf("Invalid or expired") !== -1) {
        errorType = "github_auth";
      } else if (msg.indexOf("403") !== -1 || msg.indexOf("rate limit") !== -1) {
        errorType = "github_rate_limit";
      } else if (msg.indexOf("404") !== -1 || msg.indexOf("not found") !== -1 || msg.indexOf("Not Found") !== -1) {
        errorType = "github_not_found";
      } else if (msg.indexOf("WASM") !== -1 || msg.indexOf("Worker") !== -1) {
        errorType = "wasm_load";
      }
      t("wasm_scan_error", { error_type: errorType, scan_source: getScanSource() });
      alert("Error: " + err.message);
      setState("idle");
    }

    // Fetch files with concurrency limit of 6, skipping nulls (oversized)
    function fetchAllFiles(owner, repo, branch, paths) {
      var results = [];
      var fetched = 0;
      var idx = 0;
      var concurrency = 6;
      var authError = null;

      function next() {
        if (authError || idx >= paths.length) return Promise.resolve();
        var i = idx++;
        var path = paths[i];
        return fetchRawFile(owner, repo, branch, path)
          .then(function(content) {
            fetched++;
            if (content) results.push({ path: path, content: content });
            loadingSub.textContent = fetched + " / " + paths.length + " fetched";
          })
          .catch(function(err) {
            fetched++;
            if (err.httpStatus === 403 || err.httpStatus === 401) {
              authError = new Error("Permission denied. Your token needs the Contents: Read-only permission for this repository.\n\nUpdate your token at: github.com/settings/personal-access-tokens");
            } else if (err.httpStatus === 404 && patValidated) {
              authError = new Error("Repository not accessible. Make sure your token has access to this repository and the Contents: Read-only permission.");
            }
          })
          .then(next);
      }

      var workers = [];
      for (var w = 0; w < Math.min(concurrency, paths.length); w++) {
        workers.push(next());
      }
      return Promise.all(workers).then(function() {
        if (authError) throw authError;
        return results;
      });
    }

    // Scan files sequentially via worker (worker thread does the heavy lifting)
    function scanMultipleFiles(fileContents) {
      var allFindings = [];
      var filePaths = [];
      var done = 0;
      var chain = Promise.resolve();

      fileContents.forEach(function(fc) {
        chain = chain.then(function() {
          var filename = fc.path.split("/").pop();
          loadingSub.textContent = (++done) + " / " + fileContents.length + " scanned";
          return workerScan(fc.content, filename).then(function(jsonStr) {
            var result = JSON.parse(jsonStr);
            filePaths.push(fc.path);
            (result.findings || []).forEach(function(f) {
              f.file_path = fc.path;
              allFindings.push(f);
            });
          });
        });
      });

      return chain.then(function() {
        return {
          merged: { findings: allFindings, files_scanned: filePaths.length },
          files: filePaths,
          label: filePaths.length + " files"
        };
      });
    }

    // --- Paste/upload scan ---
    scanBtn.addEventListener("click", function() {
      var content = contentInput.value.trim();
      if (!content) return;

      var filename = currentFilename || ("skill" + selectedExt);
      t("scan_start", { source: wasFileUpload ? "upload" : "paste", file_ext: filename.indexOf(".") !== -1 ? filename.split(".").pop() : "unknown", content_length: content.length });
      sourceUrl = null;

      setState("loading");
      loadingText.textContent = "Scanning...";
      loadingSub.textContent = "First scan loads the WASM engine (~2 MB, cached after)";

      var t0 = performance.now();

      workerScan(content, filename).then(function(jsonStr) {
        var elapsed = Math.round(performance.now() - t0);
        var result = JSON.parse(jsonStr);
        renderResults(result, filename, elapsed, null);
        setState("results");
        trackScan(result, elapsed);
      }).catch(handleError);
    });

    // --- GA4 tracking ---
    function trackScan(result, elapsed) {
      var findings = result.findings || [];
      var counts = countSeverities(findings);
      var score = computeScore(counts);
      var grade = scoreToGrade(score);
      var topSev = "none";
      for (var i = 0; i < SEVERITY_ORDER.length; i++) {
        if (counts[SEVERITY_ORDER[i]] > 0) { topSev = SEVERITY_ORDER[i]; break; }
      }
      var cats = {};
      findings.forEach(function(f) { if (f.category) cats[f.category] = true; });
      t("wasm_scan", {
        findings_count: findings.length,
        score: score,
        grade: grade,
        duration_ms: elapsed,
        source: sourceUrl ? "github" : "paste",
        files_scanned: result.files_scanned || 1,
        scan_source: getScanSource(),
        top_severity: topSev,
        categories_found: Object.keys(cats).join(","),
        load_time_ms: wasmLoadTimeMs ? Math.round(wasmLoadTimeMs) : null
      });
    }

    // --- Reset ---
    resetBtn.addEventListener("click", function() {
      t("scan_reset", { previous_source: getScanSource() });
      contentInput.value = "";
      githubUrl.value = "";
      scanBtn.disabled = true;
      fetchBtn.disabled = true;
      filenameDisplay.classList.add("hidden");
      currentFilename = "skill" + selectedExt;
      sourceUrl = null;
      wasFileUpload = false;
      lastScanData = null;
      document.getElementById("results-body").innerHTML = "";
      document.getElementById("files-scanned-section").classList.add("hidden");
      document.getElementById("result-source-link").classList.add("hidden");
      setState("idle");
    });

    // --- State management ---
    function setState(s) {
      stateIdle.classList.toggle("hidden", s !== "idle");
      stateLoading.classList.toggle("hidden", s !== "loading");
      stateResults.classList.toggle("hidden", s !== "results");
    }

    // --- Score computation ---
    function countSeverities(findings) {
      var counts = {CRITICAL:0, HIGH:0, MEDIUM:0, LOW:0, INFO:0};
      findings.forEach(function(f) {
        var sev = typeof f.severity === "number" ? SEVERITY_MAP[f.severity] : f.severity;
        if (sev && counts[sev] !== undefined) counts[sev]++;
      });
      return counts;
    }

    function computeScore(counts) {
      var score = 100 - (counts.CRITICAL * 25 + counts.HIGH * 15 + counts.MEDIUM * 8);
      return Math.max(0, Math.min(100, score));
    }

    // --- Render results ---
    function renderResults(result, label, elapsed, scannedFiles) {
      var findings = result.findings || [];

      findings = findings.map(function(f) {
        if (typeof f.severity === "number") {
          f.severity = SEVERITY_MAP[f.severity] || "INFO";
        }
        return f;
      });

      findings.sort(function(a, b) {
        var sa = SEVERITY_RANK[a.severity] || 4;
        var sb = SEVERITY_RANK[b.severity] || 4;
        if (sa !== sb) return sa - sb;
        return (a.file_path || "").localeCompare(b.file_path || "");
      });

      var counts = countSeverities(findings);
      var score = computeScore(counts);
      var grade = scoreToGrade(score);
      var gc = GRADE_COLORS[grade] || GRADE_COLORS.F;

      document.getElementById("result-filename").textContent = label;
      var gradeBadge = document.getElementById("grade-badge");
      gradeBadge.textContent = grade;
      gradeBadge.className = "w-16 h-16 text-3xl rounded-lg border-2 flex items-center justify-center font-bold " + gc;
      document.getElementById("score-label").textContent = score + "/100";

      var srcLink = document.getElementById("result-source-link");
      if (sourceUrl) { srcLink.href = sourceUrl; srcLink.classList.remove("hidden"); }
      else { srcLink.classList.add("hidden"); }

      document.getElementById("stat-score").innerHTML = '<span class="font-bold text-white">' + score + '/100</span>';
      document.getElementById("stat-findings").innerHTML = '<span class="font-bold text-white">' + findings.length + '</span>';
      document.getElementById("stat-duration").innerHTML = '<span class="font-bold text-white">' + elapsed + ' ms</span>';

      // Files scanned section (repo mode)
      var filesSection = document.getElementById("files-scanned-section");
      if (scannedFiles && scannedFiles.length > 1) {
        filesSection.classList.remove("hidden");
        document.getElementById("files-count").textContent = "(" + scannedFiles.length + ")";
        var filesList = document.getElementById("files-list");
        filesList.innerHTML = scannedFiles.map(function(p) {
          var fileFindings = findings.filter(function(f) { return f.file_path === p; }).length;
          return '<div class="flex items-center justify-between px-3 py-1.5 rounded-lg hover:bg-gray-800/30">' +
            '<span class="text-xs font-mono text-gray-400">' + escapeHtml(p) + '</span>' +
            (fileFindings > 0
              ? '<span class="text-xs font-mono text-orange-400">' + fileFindings + ' finding' + (fileFindings > 1 ? 's' : '') + '</span>'
              : '<span class="text-xs text-gray-600">clean</span>') +
            '</div>';
        }).join("");
      } else {
        filesSection.classList.add("hidden");
      }

      var body = document.getElementById("results-body");
      var html = "";

      if (findings.length > 0) {
        html += '<div class="flex flex-wrap gap-3 mb-6">';
        SEVERITY_ORDER.forEach(function(sev) {
          if (!counts[sev]) return;
          var sc = SEVERITY_COLORS[sev] || SEVERITY_COLORS.INFO;
          html += '<div class="flex items-center gap-1.5">';
          html += '<span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full border ' + sc + '">' + sev + '</span>';
          html += '<span class="text-sm font-mono text-gray-400">' + counts[sev] + '</span>';
          html += '</div>';
        });
        html += '</div>';

        html += '<div class="bg-gray-900/50 border border-gray-800 rounded-2xl p-5">';
        html += '<h2 class="text-base font-semibold text-white mb-4">Findings <span class="text-gray-500 font-normal">(' + findings.length + ')</span></h2>';
        html += '<div class="space-y-2">';
        findings.forEach(function(f) {
          var sc = SEVERITY_COLORS[f.severity] || SEVERITY_COLORS.INFO;
          html += '<div class="border border-gray-800/50 rounded-xl overflow-hidden hover:border-gray-700/50 transition-colors">';
          html += '<div class="flex items-center gap-3 px-4 py-2.5 bg-gray-800/20">';
          html += '<span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full border ' + sc + '">' + escapeHtml(f.severity) + '</span>';
          html += '<span class="font-mono text-xs text-gray-300">' + escapeHtml(f.rule_id) + '</span>';
          html += '<span class="text-xs text-gray-600 hidden sm:inline">' + escapeHtml(f.category || "") + '</span>';
          if (f.file_path && scannedFiles && scannedFiles.length > 1) {
            html += '<span class="text-xs text-gray-600 hidden sm:inline font-mono">' + escapeHtml(f.file_path) + '</span>';
          }
          if (f.line) html += '<span class="text-xs text-gray-600 ml-auto font-mono">L' + f.line + '</span>';
          html += '</div>';
          if (f.matched_text) {
            html += '<div class="px-4 py-2.5 bg-gray-950/30 border-t border-gray-800/30">';
            html += '<pre class="text-xs text-gray-400 font-mono whitespace-pre-wrap break-all overflow-x-auto leading-relaxed"><code>' + escapeHtml(f.matched_text) + '</code></pre>';
            html += '</div>';
          }
          if (f.description) {
            html += '<div class="px-4 py-2 border-t border-gray-800/30">';
            html += '<p class="text-xs text-gray-500">' + escapeHtml(f.description) + '</p>';
            html += '</div>';
          }
          html += '</div>';
        });
        html += '</div></div>';
      } else {
        html += '<div class="bg-gray-900/50 border border-gray-800 rounded-2xl p-8 text-center">';
        html += '<svg class="w-12 h-12 mx-auto mb-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">';
        html += '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />';
        html += '</svg>';
        html += '<h2 class="text-lg font-semibold text-white mb-2">No Security Issues Found</h2>';
        html += '<p class="text-sm text-gray-400 max-w-md mx-auto">Aguara\'s static analysis detected no security findings. Perfect 100/100 score.</p>';
        html += '</div>';
      }

      body.innerHTML = html;

      // Populate lastScanData for report downloads
      lastScanData = {
        findings: findings,
        counts: counts,
        score: score,
        grade: grade,
        label: label,
        elapsed: elapsed,
        scannedFiles: scannedFiles,
        sourceUrl: sourceUrl,
        scanDate: new Date().toISOString()
      };
    }

    function escapeHtml(str) {
      if (!str) return "";
      return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    // --- PAT toggle ---
    patToggle.addEventListener("click", function() {
      var isHidden = patSection.classList.contains("hidden");
      patSection.classList.toggle("hidden");
      patChevron.style.transform = isHidden ? "rotate(90deg)" : "";
      if (isHidden) t("pat_section_open");
    });

    // --- PAT connect ---
    patConnectBtn.addEventListener("click", function() {
      var token = patInput.value.trim();
      if (!token) return;
      patConnectBtn.disabled = true;
      patConnectBtn.textContent = "Validating...";
      validatePat(token).then(function() {
        githubPat = token;
        patValidated = true;
        sessionStorage.setItem("aguara_github_pat", token);
        showPatAuthenticated();
        t("wasm_github_auth", { action: "connect" });
      }).catch(function(err) {
        t("pat_validation_error");
        alert("Authentication failed: " + err.message);
        sessionStorage.removeItem("aguara_github_pat");
        githubPat = "";
        patValidated = false;
      }).then(function() {
        patConnectBtn.disabled = false;
        patConnectBtn.textContent = "Connect";
      });
    });

    // --- PAT disconnect ---
    patDisconnectBtn.addEventListener("click", function() {
      githubPat = "";
      patValidated = false;
      sessionStorage.removeItem("aguara_github_pat");
      resetPatUI();
      t("wasm_github_auth", { action: "disconnect" });
    });

    // --- Download buttons ---
    downloadJsonBtn.addEventListener("click", generateJsonReport);
    downloadHtmlBtn.addEventListener("click", generateHtmlReport);

    // --- Auto-restore PAT on page load ---
    if (githubPat) {
      validatePat(githubPat).then(function() {
        patValidated = true;
        patSection.classList.remove("hidden");
        patChevron.style.transform = "rotate(90deg)";
        showPatAuthenticated();
        t("pat_session_restored");
      }).catch(function() {
        sessionStorage.removeItem("aguara_github_pat");
        githubPat = "";
        patValidated = false;
      });
    }

    // --- Section visibility tracking (below-fold engagement) ---
    var trackedSections = {};
    var sectionObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !trackedSections[entry.target.id]) {
          trackedSections[entry.target.id] = true;
          t("section_view", { section: entry.target.id });
        }
      });
    }, { threshold: 0.3 });
    ["categories-section", "hiw-section", "why-scan-section"].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) sectionObserver.observe(el);
    });

    // --- Results scroll depth ---
    var resultsTracked = false;
    var resultsObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !resultsTracked) {
          resultsTracked = true;
          t("results_scrolled_to_end");
        }
      });
    }, { threshold: 0.5 });
    var resetBtnEl = document.getElementById("reset-btn");
    if (resetBtnEl) resultsObserver.observe(resetBtnEl);
  })();
  </script>
</Base>
