    // --- Web Worker for WASM scanning (keeps main thread free) ---
    var worker = null;
    var workerReady = false;
    var workerCallbacks = {};
    var workerIdCounter = 0;

    function getWorker() {
      if (worker) return worker;
      worker = new Worker("/wasm/scan-worker.js");
      worker.onmessage = function(e) {
        var msg = e.data;
        if (msg.type === "ready") {
          wasmLoadTimeMs = msg.loadTime;
          t("wasm_engine_ready", { load_time_ms: Math.round(msg.loadTime) });
          return;
        }
        var cb = workerCallbacks[msg.id];
        if (!cb) return;
        delete workerCallbacks[msg.id];
        if (msg.type === "result") {
          cb.resolve(msg.json);
        } else {
          cb.reject(new Error(msg.message || "Worker scan failed"));
        }
      };
      return worker;
    }

    function workerScan(content, filename) {
      return new Promise(function(resolve, reject) {
        var id = ++workerIdCounter;
        workerCallbacks[id] = { resolve: resolve, reject: reject };
        getWorker().postMessage({ type: "scan", id: id, content: content, filename: filename });
      });
    }

    // --- Tab switching ---
