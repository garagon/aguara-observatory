---
import Base from "../layouts/Base.astro";

const base = import.meta.env.BASE_URL;
---

<Base
  title="AI Agent Security Scanner"
  description="Free online security scanner for AI agent skills and MCP servers. Detects prompt injection, credential leaks, command execution, and 10 more threat categories with 173+ rules. Runs 100% in your browser via WebAssembly."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What does the Aguara security scanner detect?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Aguara detects security vulnerabilities across 13 categories including prompt injection, credential leaks, command execution, data exfiltration, MCP attacks, SSRF, supply chain risks, and more. It uses 173+ detection rules."
        }
      },
      {
        "@type": "Question",
        "name": "Is the scanner free to use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the scanner is 100% free and open source under the Apache-2.0 license. It runs entirely in your browser via WebAssembly — no account needed, no data uploaded."
        }
      },
      {
        "@type": "Question",
        "name": "Can I scan private GitHub repositories?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you can scan private repositories by connecting a GitHub Personal Access Token (PAT) with read-only Contents permission. The token stays in your browser session and is never sent to any server."
        }
      },
      {
        "@type": "Question",
        "name": "How many skills does Aguara Watch monitor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Aguara Watch continuously monitors over 46,000 AI agent skills and MCP servers across 7 public registries including Skills.sh, ClawHub, PulseMCP, mcp.so, LobeHub, Smithery, and Glama."
        }
      }
    ]
  }}
>
  <div id="scan-app">
    <!-- Idle state -->
    <div id="state-idle">
      <!-- Hero -->
      <div class="relative text-center pt-12 sm:pt-16 pb-12 mb-6">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] max-w-full h-[300px] bg-aguara-500/5 rounded-full blur-3xl -z-10"></div>
        <div class="absolute top-10 left-1/2 -translate-x-1/2 w-[300px] h-[150px] bg-aguara-400/3 rounded-full blur-2xl -z-10"></div>

<h1 class="font-bold text-white mb-6 animate-slide-up leading-[1.1]">
          <span class="block text-4xl sm:text-5xl lg:text-6xl tracking-tight">Scan Any AI Agent</span>
          <span class="block text-3xl sm:text-4xl lg:text-5xl font-semibold text-aguara-400 mt-3 tracking-normal">Security Vulnerabilities</span>
        </h1>

        <p class="text-lg text-gray-400 max-w-2xl mx-auto animate-slide-up" style="animation-delay: 100ms">
          The same engine monitoring 46,000+ skills and MCP servers daily.
        </p>
        <p class="text-sm text-gray-500 mt-2 animate-slide-up" style="animation-delay: 150ms">
          Runs locally in your browser via WebAssembly. Nothing is uploaded.
        </p>
      </div>

      <!-- Tab switcher -->
      <div class="flex gap-1 mb-6 bg-gray-900/60 rounded-xl p-1 w-fit mx-auto animate-slide-up backdrop-blur-sm border border-gray-800/50" style="animation-delay: 200ms">
        <button id="tab-url" class="tab-btn px-5 py-2 text-sm font-medium rounded-lg bg-gray-800 text-white transition-colors">GitHub URL</button>
        <button id="tab-paste" class="tab-btn px-5 py-2 text-sm font-medium rounded-lg text-gray-400 hover:text-white transition-colors">Paste / Upload</button>
      </div>

      <!-- URL input panel -->
      <div id="panel-url" class="max-w-3xl mx-auto animate-slide-up" style="animation-delay: 250ms">
        <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 sm:p-8 mb-4 backdrop-blur-sm">
          <label for="github-url" class="block text-sm text-gray-400 mb-3 font-medium">GitHub repository, file, or directory URL</label>
          <div class="flex gap-3">
            <input
              id="github-url"
              type="url"
              placeholder="https://github.com/owner/repo"
              class="flex-1 bg-gray-800/60 border border-gray-700 rounded-xl px-4 py-3 text-base text-gray-200 font-mono placeholder-gray-600 focus:outline-none focus:border-aguara-500 focus:ring-1 focus:ring-aguara-500/30 transition-all"
            />
            <button id="fetch-btn" disabled class="px-6 py-3 bg-aguara-500 hover:bg-aguara-600 disabled:bg-gray-800 disabled:text-gray-600 text-white text-sm font-semibold rounded-xl transition-all disabled:cursor-not-allowed whitespace-nowrap shadow-lg shadow-aguara-500/20 hover:shadow-aguara-500/30 disabled:shadow-none">
              Fetch &amp; Scan
            </button>
          </div>
          <p class="text-xs text-gray-600 mt-3">Supports repositories, directories, single files, and raw.githubusercontent.com URLs</p>
        </div>

        <!-- Private repo PAT section -->
        <div class="mb-4">
          <button id="pat-toggle" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-300 transition-colors group">
            <svg class="w-4 h-4 text-gray-600 group-hover:text-gray-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
            Need to scan a private repository?
            <svg id="pat-chevron" class="w-3.5 h-3.5 transition-transform text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>

          <div id="pat-section" class="hidden mt-4">
            <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-5 sm:p-6 backdrop-blur-sm">
              <!-- Token input -->
              <div id="pat-input-row">
                <label class="block text-xs text-gray-400 mb-2 font-medium">GitHub Personal Access Token</label>
                <div class="flex gap-3">
                  <input
                    id="pat-input"
                    type="password"
                    autocomplete="off"
                    placeholder="github_pat_..."
                    class="flex-1 bg-gray-800/60 border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-gray-200 font-mono placeholder-gray-600 focus:outline-none focus:border-aguara-500 focus:ring-1 focus:ring-aguara-500/30 transition-all"
                  />
                  <button id="pat-connect-btn" class="px-5 py-2.5 bg-gray-700 hover:bg-gray-600 text-white text-sm font-medium rounded-xl transition-colors whitespace-nowrap">
                    Connect
                  </button>
                </div>
                <p class="text-xs text-gray-600 mt-2 flex items-center gap-1.5">
                  <svg class="w-3 h-3 text-emerald-500/60 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                  Token stays in your browser session only. Never sent to our servers.
                </p>
              </div>

              <!-- Authenticated state -->
              <div id="pat-authenticated" class="hidden">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3 flex-wrap">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/25">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                      Connected
                    </span>
                    <span id="pat-rate-limit" class="text-xs text-gray-500 font-mono"></span>
                  </div>
                  <button id="pat-disconnect-btn" class="text-xs text-gray-500 hover:text-red-400 transition-colors font-medium">Disconnect</button>
                </div>
                <!-- Repos list -->
                <div id="pat-repos">
                  <p class="text-xs text-gray-400 mb-3 font-medium">Your repositories</p>
                  <div id="pat-repos-list" class="space-y-1 max-h-52 overflow-y-auto rounded-xl border border-gray-800/50 bg-gray-800/20 p-2"></div>
                  <div id="pat-repos-loading" class="flex items-center gap-2 py-4 justify-center">
                    <svg class="animate-spin w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    <span class="text-xs text-gray-500">Loading repositories...</span>
                  </div>
                  <div id="pat-repos-empty" class="hidden text-xs text-gray-500 space-y-2 py-3 text-center">
                    <p>No repositories found. Your token needs:</p>
                    <ol class="list-decimal list-inside space-y-0.5 text-gray-400 text-left inline-block">
                      <li>Select the repositories you want to scan</li>
                      <li>Add permission <code class="px-1 py-0.5 bg-gray-800 rounded text-gray-300">Contents</code> &rarr; <code class="px-1 py-0.5 bg-gray-800 rounded text-gray-300">Read-only</code></li>
                    </ol>
                    <div>
                      <a href="https://github.com/settings/personal-access-tokens/new" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-aguara-400 hover:text-aguara-300 transition-colors mt-1">
                        Create a new token with the right permissions
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Footer -->
              <div class="mt-4 pt-3 border-t border-gray-800/50 flex items-center justify-end">
                <a href="https://github.com/settings/personal-access-tokens/new" target="_blank" rel="noopener noreferrer" class="text-xs text-gray-500 hover:text-aguara-400 transition-colors inline-flex items-center gap-1">
                  Create a read-only token
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Paste/upload panel (hidden by default) -->
      <div id="panel-paste" class="hidden max-w-3xl mx-auto animate-slide-up" style="animation-delay: 250ms">
        <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-6 sm:p-8 backdrop-blur-sm">
          <!-- File type selector -->
          <div class="flex flex-wrap gap-2 mb-4">
            <button class="ext-btn px-3 py-1.5 text-xs font-mono rounded-lg border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors" data-ext=".md">.md</button>
            <button class="ext-btn px-3 py-1.5 text-xs font-mono rounded-lg border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors" data-ext=".json">.json</button>
            <button class="ext-btn px-3 py-1.5 text-xs font-mono rounded-lg border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors" data-ext=".yaml">.yaml</button>
            <button class="ext-btn px-3 py-1.5 text-xs font-mono rounded-lg border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors" data-ext=".py">.py</button>
            <button class="ext-btn px-3 py-1.5 text-xs font-mono rounded-lg border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors" data-ext=".js">.js</button>
            <button class="ext-btn px-3 py-1.5 text-xs font-mono rounded-lg border border-gray-700 text-gray-400 hover:text-white hover:border-gray-500 transition-colors" data-ext=".ts">.ts</button>
          </div>

          <!-- Drop zone + textarea -->
          <div id="drop-zone" class="bg-gray-800/30 border-2 border-dashed border-gray-700 rounded-xl p-5 mb-4 transition-colors">
            <textarea
              id="content-input"
              rows="10"
              placeholder="Paste skill content here, or drag & drop a file..."
              class="w-full bg-transparent text-sm text-gray-200 font-mono placeholder-gray-600 resize-y focus:outline-none"
            ></textarea>
          </div>

          <!-- Filename display -->
          <div id="filename-display" class="hidden mb-4">
            <span class="text-xs text-gray-500">File:</span>
            <span id="filename-label" class="text-xs font-mono text-gray-300 ml-1"></span>
          </div>

          <!-- Scan button for paste mode -->
          <button id="scan-btn" disabled class="px-6 py-3 bg-aguara-500 hover:bg-aguara-600 disabled:bg-gray-800 disabled:text-gray-600 text-white text-sm font-semibold rounded-xl transition-all disabled:cursor-not-allowed shadow-lg shadow-aguara-500/20 hover:shadow-aguara-500/30 disabled:shadow-none">
            Scan
          </button>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-xs text-gray-500 mt-8 mb-20 max-w-3xl mx-auto">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          100% client-side via WASM
        </span>
        <span class="text-gray-800">&middot;</span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          Open source &mdash; Apache-2.0
        </span>
        <span class="text-gray-800">&middot;</span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-yellow-500/80" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
          Nothing is uploaded
        </span>
      </div>

      <!-- Browser compatibility -->
      <div class="flex items-center justify-center gap-3 text-[11px] text-gray-600 mb-16">
        <span class="text-gray-700">Works on</span>
        <!-- Chrome -->
        <span class="inline-flex items-center gap-1 text-gray-500">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0112 6.545h10.691A12 12 0 0012 0zM1.931 5.47A11.943 11.943 0 000 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 01-6.865-2.29zm13.342 2.166a5.446 5.446 0 011.45 5.09l.097.345-3.96 6.86A12.1 12.1 0 0024 12c0-.685-.057-1.357-.169-2.012H15.62z"/><circle cx="12" cy="12" r="3.882"/></svg>
          Chrome
        </span>
        <!-- Firefox -->
        <span class="inline-flex items-center gap-1 text-gray-500">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 5.075c.742.98 1.245 2.267 1.396 3.28-.455-.214-1.108-.39-1.79-.332-.07-.408-.2-.83-.39-1.238-.37-.79-.956-1.39-1.678-1.673a4.602 4.602 0 00-.543-.19c.243-.04.5-.058.77-.044.838.052 1.594.408 2.235.197zM12 2.08c1.844 0 3.562.534 5.015 1.455-.105.07-.224.157-.353.26-.78.63-1.648 1.87-2.758 1.78-.99-.08-1.422-.97-2.637-1.073-1.46-.124-2.643.757-3.275 1.453C7 6.99 6.734 8.363 6.884 9.748c-2.223-.942-3.828-2.95-4.584-4.28A9.865 9.865 0 0112 2.08zm-7.236 4.4c.547.977 2.06 3.163 4.453 4.143-.33.744-.541 1.575-.541 2.46 0 1.62.628 3.092 1.656 4.197-.3.04-.614.06-.942.06-4.67 0-7.593-3.752-7.593-3.752s-.298-.37-.298-.964c-.034-2.32.944-4.578 3.265-6.144zm8.156 12.238c2.752-.59 4.877-2.883 5.448-5.73.32.195.6.462.807.825.676 1.177.484 2.825-.52 4.1a9.92 9.92 0 01-5.735 2.805z"/></svg>
          Firefox
        </span>
        <!-- Safari -->
        <span class="inline-flex items-center gap-1 text-gray-500">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 1.5c5.799 0 10.5 4.701 10.5 10.5S17.799 22.5 12 22.5 1.5 17.799 1.5 12 6.201 1.5 12 1.5zm0 1.125a9.375 9.375 0 100 18.75 9.375 9.375 0 000-18.75zM8.75 7.25l7 2.5-2.5 7-7-2.5 2.5-7zm3.25 3.5a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"/></svg>
          Safari
        </span>
        <!-- Edge -->
        <span class="inline-flex items-center gap-1 text-gray-500">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M21.86 17.86q.14 0 .25.12.1.13.1.25 0 .46-.14.92-.14.47-.45 1.02-.31.54-.77 1.07-.46.52-1.13.95-.68.43-1.55.68-.88.26-1.9.26-1.14 0-2.16-.32-1.01-.32-1.85-.92-.84-.6-1.42-1.44-.58-.84-.89-1.86-.3-1.02-.3-2.23 0-1.78.73-3.45.72-1.67 1.96-2.97 1.24-1.3 2.86-2.09Q16.86 9 18.63 9q1.45 0 2.24.43.79.42.79 1.07 0 .25-.06.46-.05.22-.17.43-.12.2-.15.28-.03.08-.03.15 0 .24.2.41.19.17.19.37 0 .36-.42.88-.42.52-1.18.93-.77.4-1.8.68-1.04.28-2.3.28-1.65 0-2.88-.63-.64 1.47-.64 2.85 0 .42.08.85.07.43.27.82.2.4.52.73.33.33.83.54.5.2 1.16.2 1.07 0 1.96-.3.89-.31 1.57-.74.68-.44 1.17-.92.48-.49.77-.9.28-.41.4-.65.12-.23.22-.23z"/><path d="M10.88 4.35Q12.16 3 14.13 3q.74 0 1.42.2-.55.5-1.05 1.24-.5.73-.9 1.59-.38.87-.65 1.77-.26.9-.37 1.75-.1.85-.1 1.57 0 .26.02.59.47-.1 1.09-.37.62-.28 1.2-.74.59-.46.92-1.12.34-.66.34-1.48 0-.1-.01-.2-.02-.1-.03-.2 1.33 1.06 1.33 3.14 0 1.73-.72 3.02-.72 1.28-1.78 1.28-.68 0-1.2-.22-.52-.22-1-.58-.49-.36-1.03-.59-.53-.23-1.27-.23-1.66 0-2.91 1.3-.3-.48-.5-1.03-.2-.56-.28-1.05-.08-.5-.08-.93 0-1.35.55-2.77.54-1.43 1.5-2.6z"/></svg>
          Edge
        </span>
      </div>

      <!-- Stats bar -->
      <div class="border-t border-b border-gray-800/60 py-10 mb-16">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-4xl mx-auto text-center">
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-white">46K+</p>
            <p class="text-xs text-gray-500 mt-1">Skills & MCP servers scanned</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-white">7</p>
            <p class="text-xs text-gray-500 mt-1">Registries monitored daily</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-white">173+</p>
            <p class="text-xs text-gray-500 mt-1">Detection rules</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-white">13</p>
            <p class="text-xs text-gray-500 mt-1">Security categories</p>
          </div>
        </div>
      </div>

      <!-- What the scanner checks -->
      <div id="categories-section" class="mb-16 max-w-4xl mx-auto">
        <div class="text-center mb-8">
          <h2 class="text-xl font-bold text-white mb-3">What the scanner detects</h2>
          <p class="text-sm text-gray-500">Every scan checks for vulnerabilities across 13 security categories</p>
        </div>

        <div class="flex flex-wrap justify-center gap-2">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full bg-red-500/10 text-red-400 border border-red-500/20">
