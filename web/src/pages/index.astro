        /* Card glow when energy pulse arrives */
        .hiw-step.hiw-glow {
          border-color: rgba(240, 136, 68, 0.35);
          box-shadow: 0 0 40px rgba(240, 136, 68, 0.12), inset 0 0 30px rgba(240, 136, 68, 0.03);
        }
        .hiw-step.hiw-glow .hiw-icon {
          transform: scale(1.08);
          box-shadow: 0 0 28px rgba(240, 136, 68, 0.25);
        }

        .hiw-icon {
          transition: transform 0.4s ease, box-shadow 0.4s ease;
        }
        .hiw-step:hover .hiw-icon {
          transform: scale(1.1);
          box-shadow: 0 0 24px rgba(240, 136, 68, 0.2);
        }

        /* Energy pulse — horizontal connector */
        .energy-pulse {
          position: absolute;
          top: -2px;
          left: -40%;
          width: 40%;
          height: 6px;
          border-radius: 3px;
          background: linear-gradient(90deg, transparent, rgba(240, 136, 68, 0.5), rgba(240, 136, 68, 0.9), rgba(240, 136, 68, 0.5), transparent);
          animation: energyFlow 3s ease-in-out infinite;
          filter: blur(1px);
        }
        .energy-pulse-delayed {
          animation-delay: 1.5s;
        }

        @keyframes energyFlow {
          0%   { left: -40%; opacity: 0; }
          8%   { opacity: 1; }
          92%  { opacity: 1; }
          100% { left: 100%; opacity: 0; }
        }

        /* Energy pulse — vertical connector (mobile) */
        .energy-pulse-v {
          position: absolute;
          left: -2px;
          top: -40%;
          height: 40%;
          width: 6px;
          border-radius: 3px;
          background: linear-gradient(180deg, transparent, rgba(240, 136, 68, 0.5), rgba(240, 136, 68, 0.9), rgba(240, 136, 68, 0.5), transparent);
          animation: energyFlowV 3s ease-in-out infinite;
          filter: blur(1px);
        }
        .energy-pulse-v.energy-pulse-delayed {
          animation-delay: 1.5s;
        }

        @keyframes energyFlowV {
          0%   { top: -40%; opacity: 0; }
          8%   { opacity: 1; }
          92%  { opacity: 1; }
          100% { top: 100%; opacity: 0; }
        }

        /* Connector glow track */
        .hiw-connector {
          box-shadow: 0 0 8px rgba(240, 136, 68, 0.04);
        }

        /* Stagger visibility for desktop 5-col grid children */
        .sm\:grid > .hiw-step:nth-child(1) { transition-delay: 0s; }
        .sm\:grid > .hiw-step:nth-child(3) { transition-delay: 0.2s; }
        .sm\:grid > .hiw-step:nth-child(5) { transition-delay: 0.4s; }

        /* Stagger for mobile stacked */
        .sm\:hidden > .hiw-step:nth-child(1) { transition-delay: 0s; }
        .sm\:hidden > .hiw-step:nth-child(3) { transition-delay: 0.15s; }
        .sm\:hidden > .hiw-step:nth-child(5) { transition-delay: 0.3s; }
      </style>

      <script is:inline>
        // Intersection Observer for How It Works scroll animation
        (function() {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('hiw-visible');
              }
            });
          }, { threshold: 0.15 });

          document.querySelectorAll('.hiw-step').forEach(function(el) {
            observer.observe(el);
          });

          // Sync card glow with energy pulse timing
          // Pulse animation: 3s total, pulse travels left→right
          // Step 1 glows at start (0s), Step 2 when pulse 1 arrives (2.7s), Step 3 when pulse 2 arrives (2.7+1.5=4.2s)
          var CYCLE = 3000;    // matches animation duration
          var DELAY2 = 1500;   // matches .energy-pulse-delayed
          var GLOW_DUR = 600;  // how long the glow stays

          function getDesktopSteps() {
            var grid = document.querySelector('.hiw-section .sm\\:grid');
            if (!grid || window.innerWidth < 640) return null;
            return grid.querySelectorAll('.hiw-step');
          }
          function getMobileSteps() {
            var stack = document.querySelector('.hiw-section .sm\\:hidden');
            if (!stack || window.innerWidth >= 640) return null;
            return stack.querySelectorAll('.hiw-step');
          }

          function glowStep(step) {
            step.classList.add('hiw-glow');
            setTimeout(function() { step.classList.remove('hiw-glow'); }, GLOW_DUR);
          }

          function startGlowCycle() {
            // Step 1 glows at t=0
            // Pulse 1 starts at t=0, arrives at step 2 at ~t=2.7s (90% of 3s)
            // Pulse 2 starts at t=1.5s, arrives at step 3 at ~t=1.5+2.7=4.2s
            var steps = getDesktopSteps() || getMobileSteps();
            if (!steps || steps.length < 3) return;

            // Step 1 glows immediately
            glowStep(steps[0]);

            // Step 2 glows when pulse 1 arrives
            setTimeout(function() { glowStep(steps[1]); }, CYCLE * 0.9);

            // Step 3 glows when pulse 2 arrives
            setTimeout(function() { glowStep(steps[2]); }, DELAY2 + CYCLE * 0.9);
          }

          // Full cycle length = max(CYCLE, DELAY2 + CYCLE) = 4.5s, add buffer
          var fullCycle = DELAY2 + CYCLE + GLOW_DUR;
          // Start first cycle after a short delay, then repeat
          setTimeout(function() {
            startGlowCycle();
            setInterval(startGlowCycle, fullCycle);
          }, 1000);
        })();
      </script>

