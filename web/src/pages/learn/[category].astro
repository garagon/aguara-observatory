---
import Base from "../../layouts/Base.astro";
import { getCategorySkills, getRulesKB } from "../../lib/api";
import { severityColors, registryNames, gradeBarColors } from "../../lib/constants";
import learnContent from "../../data/learn-content.json";

export function getStaticPaths() {
  return Object.keys(learnContent).map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params;
const content = learnContent[category as keyof typeof learnContent];
const catData = getCategorySkills(category!);
const rulesKB = getRulesKB();
const base = import.meta.env.BASE_URL;

if (!content) {
  return Astro.redirect("/categories/");
}

const affectedCount = catData?.skill_count ?? 0;
const ruleDetails = content.rules
  .map((rid: string) => rulesKB[rid])
  .filter(Boolean);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": `${content.title} in AI Agent Skills`,
      "description": content.tagline,
      "url": `https://watch.aguarascan.com/learn/${category}/`,
      "author": { "@type": "Organization", "name": "Aguara", "url": "https://aguarascan.com" },
      "publisher": { "@type": "Organization", "name": "Aguara Watch" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://watch.aguarascan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Learn", "item": "https://watch.aguarascan.com/learn/" },
        { "@type": "ListItem", "position": 3, "name": content.title },
      ],
    },
  ],
};
---

<Base title={`${content.title} in AI Agents`} description={content.tagline} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <nav class="mb-6 flex items-center gap-2 text-sm text-gray-500">
    <a href={`${base}learn/`} class="hover:text-aguara-400 transition-colors">Learn</a>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    <span class="text-gray-300">{content.title}</span>
  </nav>

  <!-- Header -->
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight mb-3">{content.title}</h1>
    <p class="text-lg text-gray-400 max-w-3xl">{content.tagline}</p>
    <div class="flex flex-wrap gap-4 mt-4 text-sm">
      <span class="text-gray-500">{content.rules.length} detection rules</span>
      {affectedCount > 0 && (
        <a href={`${base}categories/${category}/`} class="text-aguara-400 hover:text-aguara-300 transition-colors">
          {affectedCount.toLocaleString()} skills affected &rarr;
        </a>
      )}
    </div>
  </div>

  <div class="max-w-3xl">
    <!-- What is it -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4">What is {content.title.toLowerCase()}?</h2>
      <div class="prose-custom">
        {content.what.split("\n\n").map((p: string) => (
          <p class="text-gray-300 text-[15px] leading-relaxed mb-4">{p}</p>
        ))}
      </div>
    </section>

    <!-- Why it matters -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4">Why this matters for AI agents</h2>
      <div class="prose-custom">
        {content.why.split("\n\n").map((p: string) => (
          <p class="text-gray-300 text-[15px] leading-relaxed mb-4">{p}</p>
        ))}
      </div>
    </section>

    <!-- Real-world examples -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4">Real-world examples</h2>
      <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-5">
        {content.examples.split("\n\n").map((p: string) => (
          <p class="text-gray-300 text-[15px] leading-relaxed mb-4 last:mb-0">{p}</p>
        ))}
      </div>
    </section>

    <!-- How to protect -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4">How to protect against it</h2>
      <div class="prose-custom">
        {content.protect.split("\n\n").map((p: string) => (
          <p class="text-gray-300 text-[15px] leading-relaxed mb-4">{p}</p>
        ))}
      </div>
    </section>

    <!-- Detection rules -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-white mb-4">Aguara detection rules ({content.rules.length})</h2>
      <div class="bg-gray-900/50 border border-gray-800 rounded-xl overflow-hidden">
        <div class="divide-y divide-gray-800/50">
          {content.rules.map((rid: string) => {
            const rule = rulesKB[rid];
            if (!rule) return null;
            const sc = severityColors[rule.severity] || severityColors.INFO;
            return (
              <div class="px-4 py-3 flex items-start gap-3">
                <span class={`inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full border shrink-0 mt-0.5 ${sc}`}>{rule.severity}</span>
                <div class="min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="text-sm text-gray-200 font-medium">{rule.name}</span>
                    <span class="text-xs text-gray-600 font-mono">{rid}</span>
                  </div>
                  <p class="text-xs text-gray-500 mt-0.5">{rule.description}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  </div>

  <!-- CTA: Scan your skills -->
  <div class="bg-gray-900/50 border border-gray-800 rounded-xl p-6 text-center max-w-3xl">
    <p class="text-gray-300 mb-3">Want to check if your skills have {content.title.toLowerCase()} issues?</p>
    <a href={base} class="inline-flex items-center gap-2 px-5 py-2.5 bg-aguara-500 hover:bg-aguara-600 text-white text-sm font-medium rounded-lg transition-colors">
      Scan now (free, runs in your browser)
    </a>
  </div>
</Base>
