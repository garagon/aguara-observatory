---
import Base from "../../layouts/Base.astro";
import { getCategories } from "../../lib/api";
import learnContent from "../../data/learn-content.json";
import { severityColors } from "../../lib/constants";

const categories = getCategories();
const base = import.meta.env.BASE_URL;

const learnEntries = Object.entries(learnContent).map(([slug, content]) => {
  const catData = categories.find((c) => c.category === slug);
  return {
    slug,
    ...content,
    findingCount: catData?.count ?? 0,
  };
}).sort((a, b) => b.findingCount - a.findingCount);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": "AI Agent Security Threats Guide",
      "description": "Learn about the 13 categories of security threats in AI agent skills and MCP servers. Detection rules, real-world examples, and remediation guidance.",
      "url": "https://watch.aguarascan.com/learn/",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://watch.aguarascan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Learn" },
      ],
    },
  ],
};
---

<Base
  title="AI Agent Security Threats Guide"
  description="Learn about the 13 categories of security threats in AI agent skills and MCP servers. Detection rules, real-world examples, and remediation guidance."
  jsonLd={jsonLd}
>
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight mb-3">Security Threats in AI Agent Skills</h1>
    <p class="text-lg text-gray-400 max-w-3xl">
      AI agent skills and MCP servers face 13 categories of security threats.
      Aguara detects them with 188+ rules across pattern matching, NLP analysis, and taint tracking.
      Each guide below explains the threat, shows real examples, and tells you how to protect your agents.
    </p>
  </div>

  <div class="grid gap-4">
    {learnEntries.map((entry) => (
      <a
        href={`${base}learn/${entry.slug}/`}
        class="block bg-gray-900/50 border border-gray-800 rounded-xl p-5 hover:border-aguara-500/40 hover:bg-gray-800/30 transition-all group"
      >
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <h2 class="text-lg font-semibold text-white group-hover:text-aguara-400 transition-colors mb-1">
              {entry.title}
            </h2>
            <p class="text-sm text-gray-400 line-clamp-2">{entry.tagline}</p>
            <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
              <span>{entry.rules.length} rules</span>
              {entry.findingCount > 0 && (
                <span>{entry.findingCount.toLocaleString()} findings detected</span>
              )}
            </div>
          </div>
          <svg class="w-5 h-5 text-gray-600 group-hover:text-aguara-400 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</Base>
