---
import Base from "../../layouts/Base.astro";
import { getRegistries } from "../../lib/api";
import { registryNames } from "../../lib/constants";
import registryReports from "../../data/registry-reports.json";

const registries = getRegistries();
const base = import.meta.env.BASE_URL;

const reports = Object.entries(registryReports).map(([id, report]) => {
  const reg = registries.find((r) => r.id === id);
  return {
    id,
    ...report,
    skillCount: reg?.skill_count ?? 0,
    avgScore: reg?.avg_score ?? 100,
  };
}).sort((a, b) => b.skillCount - a.skillCount);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": "AI Agent Registry Security Reports",
      "description": "Security analysis reports for every public AI agent skill registry monitored by Aguara Watch.",
      "url": "https://watch.aguarascan.com/reports/",
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://watch.aguarascan.com/" },
        { "@type": "ListItem", "position": 2, "name": "Reports" },
      ],
    },
  ],
};
---

<Base
  title="Registry Security Reports"
  description="Security analysis reports for every public AI agent skill registry. Live data from continuous scanning of 58,000+ skills."
  jsonLd={jsonLd}
>
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold text-white tracking-tight mb-3">Registry Security Reports</h1>
    <p class="text-lg text-gray-400 max-w-3xl">
      Aguara Watch scans every public AI agent skill registry continuously. These reports summarize the security posture of each registry, how we scan them, and what we find.
    </p>
  </div>

  <div class="grid gap-4">
    {reports.map((report) => (
      <a
        href={`${base}reports/${report.id}/`}
        class="block bg-gray-900/50 border border-gray-800 rounded-xl p-5 hover:border-aguara-500/40 hover:bg-gray-800/30 transition-all group"
      >
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0">
            <h2 class="text-lg font-semibold text-white group-hover:text-aguara-400 transition-colors mb-1">
              {report.title}
            </h2>
            <p class="text-sm text-gray-400 line-clamp-2">{report.tagline}</p>
            <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
              <span>{report.skillCount.toLocaleString()} skills</span>
              <span>Avg score: {Math.round(report.avgScore)}/100</span>
            </div>
          </div>
          <svg class="w-5 h-5 text-gray-600 group-hover:text-aguara-400 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</Base>
